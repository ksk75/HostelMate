<?xml version="1.0" encoding="UTF-8"?>
<!--
    HostelMate — Web Application Deployment Descriptor
    Configures servlets, filters, session management, and error pages.
-->
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>HostelMate</display-name>
    <description>Hostel Expense Management System</description>

    <!-- ============================================================ -->
    <!-- Welcome File (Landing Page)                                   -->
    <!-- ============================================================ -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ============================================================ -->
    <!-- Session Configuration (30 minute timeout)                     -->
    <!-- ============================================================ -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ============================================================ -->
    <!-- Character Encoding Filter                                     -->
    <!-- ============================================================ -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.hostelmate.filter.EncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ============================================================ -->
    <!-- Authentication Filter                                         -->
    <!-- Protects all pages under /student/* and /admin/*              -->
    <!-- ============================================================ -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.hostelmate.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/student/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <!-- ============================================================ -->
    <!-- Error Pages                                                   -->
    <!-- ============================================================ -->
    <error-page>
        <error-code>404</error-code>
        <location>/jsp/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/jsp/error/500.jsp</location>
    </error-page>
    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/jsp/error/500.jsp</location>
    </error-page>

</web-app>
